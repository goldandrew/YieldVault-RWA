# Backend Server Configuration - LOCAL DEVELOPMENT
# Copy this to .env.local and customize for your local environment
# This file demonstrates local development configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting Configuration (relaxed for local dev)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=300

# Stellar RPC Configuration - LOCAL/TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Vault Configuration - REPLACE WITH YOUR LOCAL CONTRACT ID
VAULT_CONTRACT_ID=

# Database Configuration - LOCAL
DATABASE_URL=postgresql://localhost:5432/yieldvault_dev
DATABASE_REPLICA_URL=
DATABASE_POOL_SIZE=5
PRISMA_POOL_MAX=5
PRISMA_POOL_TIMEOUT_MS=10000
PRISMA_QUERY_TIMEOUT_MS=5000

# Admin audit log persistence mode
ADMIN_AUDIT_LOG_STORAGE=memory

# CORS Configuration - LOCAL
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Email Notification Configuration - LOCAL (mock mode)
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=dev@localhost

# Latency SLO Monitoring Configuration - LOCAL (relaxed)
SLO_READ_THRESHOLD_MS=500
SLO_WRITE_THRESHOLD_MS=1000
SLO_EVALUATION_WINDOW_MS=60000
SLO_ALERT_COOLDOWN_MS=300000
SLO_CHECK_INTERVAL_MS=30000

# Alert Integration Configuration - LOCAL (disabled or mock)
ALERT_TYPE=slack
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
