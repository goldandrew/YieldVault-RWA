# Backend Server Configuration - PRODUCTION
# Copy this to .env.production and customize for your production environment
# NEVER commit the actual .env.production file with real secrets

# Server Configuration
PORT=3000
NODE_ENV=production

# Rate Limiting Configuration (strict for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=30

# Stellar RPC Configuration - PRODUCTION MAINNET
# IMPORTANT: Use mainnet RPC URL for production
STELLAR_RPC_URL=https://soroban-mainnet.stellar.org
STELLAR_NETWORK=mainnet
STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# Vault Configuration - PRODUCTION CONTRACT ID
# CRITICAL: Replace with your deployed mainnet contract ID
VAULT_CONTRACT_ID=

# Database Configuration - PRODUCTION
# CRITICAL: Use secure connection strings with SSL
DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/yieldvault_prod?sslmode=require
DATABASE_REPLICA_URL=postgresql://user:password@prod-db-replica.example.com:5432/yieldvault_prod?sslmode=require
DATABASE_POOL_SIZE=20
PRISMA_POOL_MAX=20
PRISMA_POOL_TIMEOUT_MS=10000
PRISMA_QUERY_TIMEOUT_MS=5000

# Admin audit log persistence mode
ADMIN_AUDIT_LOG_STORAGE=prisma

# Prisma runtime connection settings
PRISMA_POOL_SIZE=20
PRISMA_POOL_TIMEOUT_SEC=10
PRISMA_QUERY_TIMEOUT_MS=5000
PRISMA_TX_MAX_WAIT_MS=5000
PRISMA_TX_TIMEOUT_MS=10000

# CORS Configuration - PRODUCTION
# IMPORTANT: Restrict to your production domains only
CORS_ALLOWED_ORIGINS=https://app.yieldvault.finance,https://www.yieldvault.finance

# Email Notification Configuration - PRODUCTION
# CRITICAL: Use production API keys
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=notifications@yieldvault.finance

# Latency SLO Monitoring Configuration - PRODUCTION
SLO_READ_THRESHOLD_MS=200
SLO_WRITE_THRESHOLD_MS=500
SLO_EVALUATION_WINDOW_MS=300000
SLO_ALERT_COOLDOWN_MS=900000
SLO_CHECK_INTERVAL_MS=60000

# Alert Integration Configuration - PRODUCTION
# CRITICAL: Use production webhook URLs and keys
ALERT_TYPE=both
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/PROD/WEBHOOK
PAGERDUTY_INTEGRATION_KEY=your-production-integration-key

# Optional: Redis Configuration for production caching
# REDIS_URL=redis://prod-redis.example.com:6379
# CACHE_TTL=300
