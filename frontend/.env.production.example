# Frontend Configuration - PRODUCTION
# Copy this to .env.production and customize for your production environment
# NEVER commit the actual .env.production file with real values

# Stellar Network Configuration - MAINNET
# CRITICAL: Use mainnet RPC URL for production
VITE_SOROBAN_RPC_URL=https://soroban-mainnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# Vault Contract ID - PRODUCTION
# CRITICAL: Replace with your deployed mainnet contract ID
VITE_VAULT_CONTRACT_ID=

# Feature Flags - PRODUCTION
VITE_FF_ANALYTICS_PAGE=true
VITE_FF_ADVANCED_CHARTS=false
VITE_FF_DEBUG_MODE=false

# Backend API URL - PRODUCTION
VITE_API_BASE_URL=https://api.yieldvault.finance

# Sentry Configuration - PRODUCTION
# CRITICAL: Use production Sentry DSN
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Analytics Configuration - PRODUCTION (if applicable)
# VITE_ANALYTICS_ID=
# VITE_GTM_ID=
